HOST=0.0.0.0
PORT=3000
MAX_PORT_ATTEMPTS=10

# Windows office PC recommendation:
# FIELD_SURVEY_DATA_DIR=C:\FieldSurvey\data
FIELD_SURVEY_DATA_DIR=

# Public address shown to admins/field workers in credential messages.
# Example:
# PUBLIC_SERVER_URL=http://192.168.1.100:3000
PUBLIC_SERVER_URL=
MOBILE_SERVER_URL=

# Optional generic credential delivery webhook.
# Your webhook should accept JSON: { channel, to, message, user }
CREDENTIAL_WEBHOOK_URL=
SMS_WEBHOOK_URL=
WHATSAPP_WEBHOOK_URL=

JWT_SECRET=change-this-before-production
